#!/bin/bash
set -e

echo "==> Bootstrapping dotfiles..."

{{ if eq .chezmoi.os "darwin" -}}
# --- Homebrew ---
if ! command -v brew &> /dev/null; then
  echo "==> Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{ end -}}

# --- mise ---
if ! command -v mise &> /dev/null; then
  echo "==> Installing mise..."
  curl -fsSL https://mise.run | sh
fi
echo "==> Installing tools via mise..."
export PATH="$HOME/.local/bin:$PATH"
mise install

# --- antidote (zsh plugin manager) ---
if [[ ! -d "$HOME/.antidote" ]]; then
  echo "==> Installing antidote..."
  git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# --- Node CLI tools (on top of mise-installed Node) ---
# agent-browser is kept here rather than in mise config because `agent-browser
# install` (which downloads the matched Chrome for Testing binary) is a
# required post-install step that mise can't orchestrate.
# Invoke the just-installed binary by absolute path via `npm config get
# prefix` — mise (esp. on WSL) doesn't auto-shim arbitrary npm globals,
# so a freshly-installed bin isn't on PATH even within the same shell.
mise exec -- bash -c '
  npm install -g agent-browser
  "$(npm config get prefix)/bin/agent-browser" install
'

# Claude Code skill stub for agent-browser. Thin SKILL.md that defers to
# `agent-browser skills get core` at runtime, so the workflow content stays
# version-matched to the installed CLI. `npx skills add` errors on re-add, so
# guard with a file test. Two `-y` flags: outer is npx's "ok to download?",
# inner is skills' "ok to install?". Without the inner one, skills prompts
# interactively for the install + the find-skills recommendation.
[ -f "$HOME/.claude/skills/agent-browser/SKILL.md" ] || \
  mise exec -- npx -y skills add vercel-labs/agent-browser -y

# Context7 MCP server (up-to-date library docs). `claude mcp add` errors
# (non-zero) if the server already exists — `|| true` keeps re-runs idempotent.
mise exec -- claude mcp add --transport stdio --scope user context7 -- npx -y @upstash/context7-mcp || true

{{ if eq .chezmoi.os "darwin" -}}
# Lightpanda: opt-in alternative engine for agent-browser. Fast for SSR/URL-
# level checks but limited DOM/event fidelity -- does NOT reliably drive
# React's synthetic event handlers, so the default engine stays Chrome.
# Invoke via `agent-browser --engine lightpanda <cmd>`. Direct binary
# download (no Homebrew formula), so a file-exists guard is needed.
if [ ! -x "$HOME/.local/bin/lightpanda" ]; then
  mkdir -p "$HOME/.local/bin"
  arch="aarch64"; [ "$(uname -m)" = "x86_64" ] && arch="x86_64"
  curl -fsSL -o "$HOME/.local/bin/lightpanda" \
    "https://github.com/lightpanda-io/browser/releases/download/nightly/lightpanda-${arch}-macos"
  chmod +x "$HOME/.local/bin/lightpanda"
fi
{{ else if eq .chezmoi.os "linux" -}}
# Font has to be on the host filesystem (flatpak apps see it via the portal).
if ! fc-list 2>/dev/null | grep -qi "JetBrainsMono Nerd"; then
  echo "==> Installing JetBrains Mono Nerd Font..."
  mkdir -p ~/.local/share/fonts
  curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz | tar -xJ -C ~/.local/share/fonts
  fc-cache -f ~/.local/share/fonts
fi
{{ end -}}

echo "==> Done!"
