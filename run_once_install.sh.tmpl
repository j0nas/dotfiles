#!/bin/bash
set -e

echo "==> Bootstrapping dotfiles..."

{{ if eq .chezmoi.os "darwin" -}}
# --- Homebrew ---
if ! command -v brew &> /dev/null; then
  echo "==> Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{ end -}}

# --- mise ---
if ! command -v mise &> /dev/null; then
  echo "==> Installing mise..."
  curl -fsSL https://mise.run | sh
fi
echo "==> Installing tools via mise..."
export PATH="$HOME/.local/bin:$PATH"
mise install

# --- antidote (zsh plugin manager) ---
if [[ ! -d "$HOME/.antidote" ]]; then
  echo "==> Installing antidote..."
  git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# --- WezTerm ---
{{ if eq .chezmoi.os "darwin" -}}
if ! command -v wezterm &> /dev/null; then
  echo "==> Installing WezTerm..."
  brew install --cask wezterm
fi
{{ else -}}
# On Windows/WSL, WezTerm runs on the Windows side.
# Copy config so Windows WezTerm finds it (WSL symlinks don't work cross-OS).
WIN_HOME="/mnt/c/Users/${USER}"
if [[ -d "$WIN_HOME" ]]; then
  echo "==> Copying WezTerm config to Windows home..."
  cp "$HOME/.wezterm.lua" "$WIN_HOME/.wezterm.lua"
fi
{{ end -}}

# --- Nerd Font ---
{{ if eq .chezmoi.os "darwin" -}}
if ! ls ~/Library/Fonts/JetBrainsMonoNerd* &> /dev/null; then
  echo "==> Installing JetBrains Mono Nerd Font..."
  brew install --cask font-jetbrains-mono-nerd-font
fi
{{ else -}}
if ! fc-list 2>/dev/null | grep -qi "JetBrainsMono Nerd"; then
  echo "==> Installing JetBrains Mono Nerd Font..."
  mkdir -p ~/.local/share/fonts
  curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz | tar -xJ -C ~/.local/share/fonts
  fc-cache -f ~/.local/share/fonts
fi
{{ end -}}

# --- GUI apps ---
# Trust each tool's idempotency (see CLAUDE.md). Add apps by appending ids.
{{ if eq .chezmoi.os "darwin" -}}
CASKS=(obsidian signal)
for c in "${CASKS[@]}"; do
  echo "==> brew install --cask $c"
  brew install --cask "$c"
done
{{ else if stat "/mnt/c/Users" -}}
WINGET_PKGS=(
  Obsidian.Obsidian
  OpenWhisperSystems.Signal
  Apple.iCloud
)
for p in "${WINGET_PKGS[@]}"; do
  echo "==> winget install $p"
  # winget exits non-zero if already installed — || true is required, not optional.
  powershell.exe -NoProfile -Command "winget install --accept-source-agreements --accept-package-agreements -e --id $p" || true
done
echo "NOTE: After first Apple.iCloud install, sign in + tick 'iCloud Drive' so the vault syncs."
{{ else if eq .chezmoi.os "linux" -}}
FLATPAKS=(md.obsidian.Obsidian org.signal.Signal)
if command -v flatpak &> /dev/null; then
  for f in "${FLATPAKS[@]}"; do
    echo "==> flatpak install $f"
    flatpak install -y --noninteractive flathub "$f"
  done
else
  echo "NOTE: flatpak not installed. Run 'sudo apt install -y flatpak' then re-apply."
fi
echo "NOTE: Linux has no iCloud client — use Syncthing/git for Obsidian cross-device sync."
{{ end -}}

# --- VS Code extensions ---
EXTENSIONS=(
  anthropic.claude-code
  bradlc.vscode-tailwindcss
  buenon.scratchpads
  catppuccin.catppuccin-vsc
)
if command -v code &> /dev/null; then
  echo "==> Installing VS Code extensions..."
  for ext in "${EXTENSIONS[@]}"; do
    code --install-extension "$ext" --force 2>/dev/null || true
  done
fi

{{ if stat "/mnt/c/Users" -}}
# --- VS Code settings (WSL → Windows) ---
WIN_HOME="/mnt/c/Users/${USER}"
VSCODE_WIN="$WIN_HOME/AppData/Roaming/Code/User"
if [[ -d "$WIN_HOME" ]]; then
  mkdir -p "$VSCODE_WIN"
  cp "$HOME/.config/Code/User/settings.json" "$VSCODE_WIN/settings.json"
fi
{{ end -}}

# --- zsh ---
if command -v zsh &> /dev/null; then
  if [[ "$SHELL" != */zsh ]]; then
    echo "==> Setting zsh as default shell..."
    chsh -s "$(which zsh)"
  fi
else
{{ if eq .chezmoi.os "darwin" -}}
  echo "NOTE: zsh should already be installed on macOS"
{{ else -}}
  echo "NOTE: Install zsh manually: sudo apt install -y zsh && chsh -s \$(which zsh)"
{{ end -}}
fi

echo "==> Done!"
