#!/bin/bash
set -e

# Claude Code installs via Anthropic's native installer rather than mise so the
# built-in background auto-updater can keep it current. mise-managed installs
# can't self-update -- you'd have to schedule `mise upgrade claude` yourself.
export PATH="$HOME/.local/bin:$PATH"
if ! command -v claude &> /dev/null; then
  echo "==> Installing Claude Code (native installer)..."
  curl -fsSL https://claude.ai/install.sh | bash
fi

# Context7 MCP server (up-to-date library docs). Remove-then-add so re-runs are
# idempotent AND actually re-register the launch command when it changes here
# (`claude mcp add` alone errors when the server already exists). Launched with
# `pnpm dlx` — corepack/npx is gone in Node 25+; pnpm comes from mise.
claude mcp remove context7 2>/dev/null || true
claude mcp add --transport stdio --scope user context7 -- pnpm dlx @upstash/context7-mcp || true
