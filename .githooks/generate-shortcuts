#!/usr/bin/env bash
# Generate SHORTCUTS.md from `# sc:` tags scattered next to the actual bindings.
#
# THE CONVENTION (works in any file that has comments — toml, lua, zsh, …):
#
#   <comment-leader> sc: <trigger> | <description> | <section>
#
#   • trigger      what you press/type:  Cmd+Alt+Shift+N , Alt+H/J/K/L , gst
#   • description  human text (required)
#   • section      optional sub-heading within the tool
#
# Examples:
#   cmd-alt-shift-n = '…'              # sc: Cmd+Alt+Shift+N | Set workspace label | Labels
#   alias gst='git status'            # sc: gst | git status | Git
#
# The collector is deliberately format-agnostic: it greps for the tag, never for
# a tool's native binding syntax. A brand-new tool needs ZERO code here — just
# add `# sc:` tags in its config. The TOOL/section a row lands under is derived
# from the SOURCE FILE (see toolname() below), so tags stay terse.
#
# Output goes to stdout; the pre-commit hook writes it to SHORTCUTS.md and
# .githooks/validate asserts the committed file matches (regenerate + diff).
# No pipefail: `git grep` exits 1 when a pattern has no matches, which is a
# legitimate empty result, not a failure of the pipeline.
set -eu
cd "$(git rev-parse --show-toplevel)"

# Docs and the tooling itself contain example `sc:` tags — never harvest those.
git grep -n -E '(#|--|//|<!--|;)[[:space:]]*sc:[[:space:]]' -- \
      ':!.githooks/*' ':!*.md' ':!README*' ':!CLAUDE.md' ':!AGENTS.md' \
  | awk '
    function trim(s){ gsub(/^[[:space:]]+|[[:space:]]+$/, "", s); return s }
    function toolname(f){
      if (f ~ /aerospace/)    return "AeroSpace"
      if (f ~ /wezterm/)      return "WezTerm"
      if (f ~ /aliases\.zsh/) return "Shell aliases"
      if (f ~ /zshrc/)        return "Zsh / shell"
      return f
    }
    function toolorder(t){
      if (t=="AeroSpace")     return 1
      if (t=="WezTerm")       return 2
      if (t=="Zsh / shell")   return 3
      if (t=="Shell aliases") return 4
      return 9
    }
    {
      # split "file:lineno:content" on the first two colons (paths have none)
      i = index($0, ":"); file = substr($0, 1, i-1); rest = substr($0, i+1)
      i = index(rest, ":"); content = substr(rest, i+1)

      p = index(content, "sc:"); body = substr(content, p+3)
      sub(/-->[[:space:]]*$/, "", body)            # strip a markdown comment close

      # split body into up to 3 fields on "|"
      trigger = body; desc = ""; section = ""
      q = index(body, "|")
      if (q) { trigger = substr(body,1,q-1); body = substr(body,q+1)
               q = index(body, "|")
               if (q) { desc = substr(body,1,q-1); section = substr(body,q+1) }
               else   { desc = body } }
      trigger = trim(trigger); desc = trim(desc); section = trim(section)

      tool = toolname(file)
      key = tool SUBSEP section
      if (!(key in seen)) { seen[key]=1; secorder[key]=++sc }   # first-seen order
      # emit: toolorder \t tool \t secorder \t section \t inputorder \t trigger \t desc
      printf "%d\t%s\t%d\t%s\t%d\t%s\t%s\n", toolorder(tool), tool, secorder[key], section, NR, trigger, desc
    }
  ' \
  | sort -t"$(printf '\t')" -k1,1n -k3,3n -k5,5n \
  | awk -F"$(printf '\t')" '
    BEGIN {
      print "# Shortcuts"
      print ""
      print "> Generated by `.githooks/generate-shortcuts` from `# sc:` tags in the configs."
      print "> Do not edit by hand — edit the tag next to the binding; it regenerates on commit."
      ptool = ""; psec = "\001"
    }
    {
      tool=$2; sec=$4; trigger=$6; desc=$7
      if (tool != ptool) { printf "\n## %s\n", tool; ptool=tool; psec="\001" }
      if (sec != psec) {
        if (sec != "") printf "\n### %s\n", sec
        print ""; print "| Shortcut | Action |"; print "| --- | --- |"
        psec=sec
      }
      printf "| `%s` | %s |\n", trigger, desc
    }
  '
