#!/bin/bash
set -e

# Converge mise-managed tools whenever the tool list changes, so `chezmoi apply`
# picks up additions/removals without needing a fresh run_once bootstrap. Mirrors
# how install-packages / install-vscode-extensions stay in sync with their data.
# mise config: {{ include "dot_config/mise/config.toml" | sha256sum }}

# Install Node first. The npm-backed tools (npm:ccusage, npm:vite-plus) shell out
# to npm at install time, and on a fresh machine no Node exists yet, so a plain
# `mise install` could fail building the npm backend. mise's npm backend uses
# mise's own node, so installing node up front is all that's needed — no external
# version manager.
echo "==> Installing Node (for the npm-backed tools)..."
mise install node

echo "==> Converging mise-managed tools..."
mise install
