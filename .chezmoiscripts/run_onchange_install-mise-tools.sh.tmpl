#!/bin/bash
set -e

# Converge mise-managed tools whenever the tool list changes, so `chezmoi apply`
# picks up additions/removals without needing a fresh run_once bootstrap. Mirrors
# how install-packages / install-vscode-extensions stay in sync with their data.
# mise config: {{ include "dot_config/mise/config.toml" | sha256sum }}

# Install the backend prerequisites first. The npm-backed tools (npm:ccusage,
# npm:vite-plus) shell out to npm, and the pipx-backed tool (check-jsonschema)
# shells out to uv; on a fresh machine neither node nor uv exists yet, so a plain
# `mise install` could fail building those backends. mise's npm/pipx backends use
# mise's own node/uv, so installing both up front is all that's needed — no
# external version manager.
echo "==> Installing backend prerequisites (Node, uv)..."
mise install node uv

echo "==> Converging mise-managed tools..."
mise install
