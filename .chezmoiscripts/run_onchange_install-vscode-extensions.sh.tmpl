#!/bin/bash
set -e

if ! command -v code &> /dev/null; then
  echo "==> code CLI not found, skipping VS Code extensions"
  exit 0
fi

DESIRED=(
{{- range .vscode_extensions }}
  {{ . }}
{{- end }}
)

# Uninstall extensions present locally but not in .chezmoidata.yaml. Read line
# by line — no `mapfile`, since macOS ships bash 3.2 which lacks it (and a bare
# `INSTALLED=($(...))` trips shellcheck SC2207).
while IFS= read -r ext; do
  [ -z "$ext" ] && continue
  keep=0
  for d in "${DESIRED[@]}"; do
    [[ "$ext" == "$d" ]] && keep=1 && break
  done
  if [[ $keep -eq 0 ]]; then
    code --uninstall-extension "$ext" || true
  fi
done < <(code --list-extensions)

for ext in "${DESIRED[@]}"; do
  code --install-extension "$ext" --force || true
done
