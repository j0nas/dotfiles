#!/bin/bash
set -e

echo "==> Bootstrapping dotfiles..."

{{ if eq .chezmoi.os "darwin" -}}
# --- Homebrew ---
if ! command -v brew &> /dev/null; then
  echo "==> Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{ end -}}

# --- mise ---
if ! command -v mise &> /dev/null; then
  echo "==> Installing mise..."
  curl -fsSL https://mise.run | sh
fi
# Backend prerequisites first, so the npm-backed mise tools have node/npm and the
# pipx-backed tool has uv available when they build. mise owns the global default
# Node version (node = ... in its config).
echo "==> Installing tools via mise (backend prerequisites first)..."
export PATH="$HOME/.local/bin:$PATH"
mise install node uv
mise install

# --- antidote (zsh plugin manager) ---
if [[ ! -d "$HOME/.antidote" ]]; then
  echo "==> Installing antidote..."
  git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# --- Node CLI tools (on top of mise-managed Node) ---
# agent-browser is installed as a pnpm global rather than a mise-managed tool
# because its post-install step — `agent-browser install`, which downloads the
# matched Chrome for Testing binary — isn't something a version manager can
# orchestrate. pnpm puts global bins in PNPM_HOME (a fixed dir, not per-Node),
# so the install survives Node switches; putting PNPM_HOME on PATH makes the
# freshly-installed binary callable by name. `mise exec` provides node + pnpm.
mise exec -- bash -c '
  export PNPM_HOME="$HOME/.local/share/pnpm"
  export PATH="$PNPM_HOME/bin:$PATH"
  pnpm add -g agent-browser
  agent-browser install
'

# Claude Code skill stub for agent-browser. Thin SKILL.md that defers to
# `agent-browser skills get core` at runtime, so the workflow content stays
# version-matched to the installed CLI. `pnpm dlx skills add` errors on re-add,
# so guard with a file test. The `-y` is skills' own "ok to install?" — without
# it, skills prompts interactively for the install + the find-skills
# recommendation. (pnpm dlx, unlike npx, needs no separate download-confirm flag.)
[ -f "$HOME/.claude/skills/agent-browser/SKILL.md" ] || \
  mise exec -- bash -c 'pnpm dlx skills add vercel-labs/agent-browser -y'

# Vite+ (vp) is provisioned declaratively via mise (npm:vite-plus in
# dot_config/mise/config.toml), installed by the `mise install` above — no
# separate curl|bash step here.

{{ if eq .chezmoi.os "darwin" -}}
# Lightpanda: opt-in alternative engine for agent-browser. Fast for SSR/URL-
# level checks but limited DOM/event fidelity -- does NOT reliably drive
# React's synthetic event handlers, so the default engine stays Chrome.
# Invoke via `agent-browser --engine lightpanda <cmd>`. Direct binary
# download (no Homebrew formula), so a file-exists guard is needed.
if [ ! -x "$HOME/.local/bin/lightpanda" ]; then
  mkdir -p "$HOME/.local/bin"
  arch="aarch64"; [ "$(uname -m)" = "x86_64" ] && arch="x86_64"
  curl -fsSL -o "$HOME/.local/bin/lightpanda" \
    "https://github.com/lightpanda-io/browser/releases/download/nightly/lightpanda-${arch}-macos"
  chmod +x "$HOME/.local/bin/lightpanda"
fi
{{ else if eq .chezmoi.os "linux" -}}
# Font has to be on the host filesystem (flatpak apps see it via the portal).
if ! fc-list 2>/dev/null | grep -qi "JetBrainsMono Nerd"; then
  echo "==> Installing JetBrains Mono Nerd Font..."
  mkdir -p ~/.local/share/fonts
  curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz | tar -xJ -C ~/.local/share/fonts
  fc-cache -f ~/.local/share/fonts
fi
{{ end -}}

echo "==> Done!"
