#!/bin/bash
set -e

# chezmoi's [git] autoCommit/autoPush only act on `chezmoi edit`/apply-driven
# commits. Direct commits in the source dir — e.g. from the /dotfiles workflow,
# which uses plain `git commit` — bypass that and sit unpushed. .git/hooks isn't
# tracked by git, so we materialize a post-commit auto-push hook in the chezmoi
# source repo here. run_onchange re-installs it whenever the hook body below
# changes.
HOOKS_DIR="{{ .chezmoi.sourceDir }}/.git/hooks"
[ -d "$HOOKS_DIR" ] || exit 0  # not a git checkout (e.g. applied from an archive)

cat > "$HOOKS_DIR/post-commit" <<'HOOK'
#!/bin/sh
# Auto-push dotfiles after each commit, so manual commits stay in sync without
# a separate push. Backgrounded so the commit returns immediately; any push
# error surfaces on the next git command rather than blocking the commit.
git push --quiet 2>/dev/null &
HOOK
chmod +x "$HOOKS_DIR/post-commit"
echo "==> Installed post-commit auto-push hook"
