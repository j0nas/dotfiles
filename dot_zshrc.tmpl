# --- Path ---
typeset -U path  # dedupe on re-source / nested shells
path=("$HOME/.local/bin" $path)
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# --- Navigation ---
setopt AUTO_CD

# --- Editor ---
export EDITOR='nano'

# --- Completion ---
# Rebuild the compdump at most once a day; otherwise load the cache with -C.
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# --- Plugins (antidote) ---
if [[ -d "$HOME/.antidote" ]]; then
  source "$HOME/.antidote/antidote.zsh"
  antidote load
fi

# --- Aliases ---
source "$HOME/.config/zsh/aliases.zsh"

# --- Tools ---

# mise (runtime manager) — must be first, other tools are installed via mise
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

# fnm (Node version manager) — installed via mise, but owns Node so mise doesn't.
# Must come after mise activation (mise provides the fnm binary). --use-on-cd
# auto-switches the active Node per .node-version / .nvmrc on directory change.
if command -v fnm &> /dev/null; then
  eval "$(fnm env --use-on-cd)"
fi

# pnpm: globals install into PNPM_HOME (a fixed dir, not a per-Node prefix), so
# a globally-installed CLI survives fnm Node switches. pnpm itself comes from
# mise — Node 25+ no longer bundles corepack — and auto-uses each project's
# "packageManager" version. The case guard keeps PATH dedup'd on re-source.
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

# starship prompt
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

# zoxide (smarter cd)
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

# fzf
if command -v fzf &> /dev/null; then
  source <(fzf --zsh)
fi

# Vite+ bin (https://viteplus.dev)
[ -f "$HOME/.vite-plus/env" ] && . "$HOME/.vite-plus/env"

# LM Studio CLI (`lms`) — the installer drops the binary in ~/.lmstudio/bin but
# leaves PATH to `lms bootstrap`, which would edit this chezmoi-managed .zshrc.
# Add it here instead. typeset -U path (above) keeps it dedup'd on re-source.
[[ -d "$HOME/.lmstudio/bin" ]] && path+=("$HOME/.lmstudio/bin")
