# --- Path ---
typeset -U path  # dedupe on re-source / nested shells
path=("$HOME/.local/bin" $path)
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# --- Navigation ---
setopt AUTO_CD

# --- Editor ---
export EDITOR='nano'

# --- Completion ---
# Rebuild the compdump at most once a day; otherwise load the cache with -C.
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# --- Plugins (antidote) ---
if [[ -d "$HOME/.antidote" ]]; then
  source "$HOME/.antidote/antidote.zsh"
  antidote load
fi

# --- Aliases ---
source "$HOME/.config/zsh/aliases.zsh"

# --- Keybindings ---
# Opt+Left/Right → jump by word. WezTerm sends the xterm CSI sequence
# \e[1;3{C,D} for Option/Alt+Arrow (modifier 3 = Alt); zsh has no default
# binding for it, so without these the tail self-inserts (you'd see ";3D" at
# the prompt). zsh's built-in word motions live on \eb/\ef (Alt+b/Alt+f).
bindkey '^[[1;3C' forward-word    # sc: Opt+→ | Jump forward a word | Word motion
bindkey '^[[1;3D' backward-word   # sc: Opt+← | Jump back a word | Word motion

# --- Tools ---

# mise (runtime manager) — must be first, other tools are installed via mise
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

# Node is managed by mise (dot_config/mise/config.toml) — the `mise activate`
# above already puts the right Node on PATH and auto-switches it per project on
# cd, via idiomatic_version_file_enable_tools reading .node-version / .nvmrc.

# pnpm: globals install into PNPM_HOME (a fixed dir, not a per-Node prefix), so
# a globally-installed CLI survives Node switches. pnpm itself comes from
# mise — Node 25+ no longer bundles corepack — and auto-uses each project's
# "packageManager" version. The case guard keeps PATH dedup'd on re-source.
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

# starship prompt
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

# zoxide (smarter cd)
# sc: z <dir> | Jump to a frecent directory | Navigation
# sc: zi | Interactive directory pick | Navigation
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

# fzf — these chords come from `fzf --zsh` (defaults, not bound here); tagged so
# they show on the cheat sheet too.
# sc: Ctrl+R | Fuzzy-search command history | fzf
# sc: Ctrl+T | Fuzzy-pick a file onto the command line | fzf
# sc: Alt+C | Fuzzy-cd into a subdirectory | fzf
if command -v fzf &> /dev/null; then
  source <(fzf --zsh)
fi

# Vite+ (vp) is provisioned via mise (npm:vite-plus), so its bin is already on
# PATH through mise's shims — no need to source the curl installer's
# ~/.vite-plus/env here.

# LM Studio CLI (`lms`) — the installer drops the binary in ~/.lmstudio/bin but
# leaves PATH to `lms bootstrap`, which would edit this chezmoi-managed .zshrc.
# Add it here instead. typeset -U path (above) keeps it dedup'd on re-source.
[[ -d "$HOME/.lmstudio/bin" ]] && path+=("$HOME/.lmstudio/bin")
